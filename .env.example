# ==========================================================================
# Affiliate Product Hub — biến môi trường mẫu
# Copy file này thành .env.local rồi điền giá trị thật. KHÔNG commit .env.local
# ==========================================================================

# --- Public (được nhúng vào client bundle — chỉ để giá trị an toàn công khai) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Link mạng xã hội hiển thị ở header/footer/link-in-bio (public)
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/yourbrand
NEXT_PUBLIC_THREADS_URL=https://threads.net/@yourbrand
NEXT_PUBLIC_INSTAGRAM_HANDLE=@yourbrand

# --- Server-only (TUYỆT ĐỐI không để lộ ra client) ---
# Service role key có toàn quyền bypass RLS — chỉ dùng trong server route/cron.
SUPABASE_SERVICE_ROLE_KEY=

# Email của tài khoản admin đầu tiên (dùng khi seed/promote role).
ADMIN_EMAIL=

# Salt để hash IP (không lưu IP thô). Sinh chuỗi ngẫu nhiên đủ dài.
IP_HASH_SALT=

# Bảo vệ route cron /api/cron/social-publish. Sinh chuỗi ngẫu nhiên đủ dài.
CRON_SECRET=

# --- Meta / Instagram Graph API (tùy chọn — thiếu vẫn chạy chế độ thủ công) ---
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# --- Threads API (tùy chọn — thiếu vẫn chạy chế độ thủ công) ---
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=
